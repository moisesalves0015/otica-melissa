rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check for administrative access
    function isAdmin() {
      return request.auth != null;
    }

    // Public catalog and store configuration
    match /landing_products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Appointments: public can request, only admin can manage
    match /appointments/{apptId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Contact Messages: public can send, only admin can manage
    match /contacts/{msgId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Client-specific collections
    // Security Note: Individual document 'get' is allowed to support the client portal 
    // without requiring secondary authentication. Global listing 'list' is restricted to Admins.
    
    match /clients/{clientId} {
      allow get: if true;
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if true;
      allow list: if isAdmin() || (request.query.limit <= 50);
      allow write: if isAdmin();
    }

    match /atendimentos/{atendId} {
      allow get: if true;
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /installments/{instId} {
      allow get: if true;
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // Default: Restrict all other paths to Admins
    match /{document=**} {
      allow read, write: if isAdmin();
    }

  }
}
